{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "rootDirectory": ".",
  "framework": "nextjs",
  "functions": {
    "agent/src/index.ts": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "env": {
    "NEXT_PUBLIC_AGENT_API": {
      "description": "0G Agent API endpoint",
      "example": "https://provus-agent.up.railway.app"
    },
    "NEXT_PUBLIC_RPC_URL": {
      "description": "0G Chain RPC",
      "example": "https://evmrpc.0g.ai"
    },
    "NEXT_PUBLIC_VERIFIER_ENGINE": {
      "description": "VerifierEngine contract address",
      "example": "0x911E87629756F34190DF34162806f00b35521FD0"
    }
  }
}
