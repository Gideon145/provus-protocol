# PROVUS Agent — 0G TESTNET profile
# Used by the parallel testnet agent (Railway service #2) so all 3 0G
# components (Chain + Compute + Storage) can run end-to-end.
# The mainnet agent (.env) keeps running unchanged on its own service.

# 0G Testnet (ChainID 16602)
ZG_PRIVATE_KEY=your_testnet_private_key_here
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602

# 0G Compute (TEE inference) — testnet endpoints
ZG_DEEPSEEK_PROVIDER=0xd9966e13a6026Fcca4b13E7ff95c94DE268C471C

# 0G Storage indexer — testnet
ZG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# Provus contracts on 0G TESTNET (filled by deploy:testnet)
STRATEGY_REGISTRY_ADDRESS=
VERIFIER_ENGINE_ADDRESS=
STRATEGY_VAULT_ADDRESS=
REPUTATION_ENGINE_ADDRESS=
ARCHIVE_REGISTRY_ADDRESS=

# Loop config
STRATEGY_ID=1
LOOP_INTERVAL_MS=15000
ARCHIVE_BATCH_SIZE=50

# HTTP /status server (use a different port if running both agents on one host)
PORT=3002
STATUS_PORT=3002

DEMO_MODE=false

# Lower ledger deposit for testnet faucet constraints (mainnet uses default 3)
ZG_COMPUTE_LEDGER_OG=0.3
